# העתק קובץ זה ל-.env (אינו נכלל ב-git) ומלא את הערכים.
#
# Required: PRIORITY_AUTH_HEADER, PRIORITY_BASE_URL, ו-DB credentials
# (DATABASE_URL או DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD).
# Optional: כל שאר המשתנים — יש להם ברירות-מחדל סבירות בקוד.

# ============================================================
#  Priority ERP  (required)
# ============================================================
PRIORITY_AUTH_HEADER=Basic <base64-encoded-user:password>
PRIORITY_BASE_URL=https://<your-priority-server>/odata/Priority/tabula.ini/<company>

# Timeout בשניות לקריאות OData. ברירת-מחדל 120, להעלות אם יש קריאות איטיות.
# PRIORITY_TIMEOUT=120

# ============================================================
#  PostgreSQL — שתי דרכים, מספיקה אחת  (required)
# ============================================================
# (1) DATABASE_URL — מומלץ ל-production / deployments חיצוניים.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# (2) משתנים בודדים — נוח לעבודה לוקלית.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=priority_cache
DB_USER=postgres
DB_PASSWORD=<your-db-password>

# גודל ה-pool. ברירות-מחדל 1..10; שנו רק אם יש צורך.
# DB_POOL_MIN=1
# DB_POOL_MAX=10

# ============================================================
#  Forecast cache  (optional)
# ============================================================
# נתיב לתיקיית מטמון של תחזיות-pickle. ברירת-מחדל: ./forecast_models_cache
# שימושי אם רוצים לרכז cache על דיסק משותף בין מכונות.
# FORECAST_CACHE_DIR=C:\path\to\shared\forecast_cache

# TTL במטמון התחזיות בשניות. ברירת-מחדל שבוע (604800).
# FORECAST_CACHE_TTL=604800

# ============================================================
#  Domain repository cache  (optional)
# ============================================================
# TTL לזיכרון-קצר של domain tables (pricing, branches, identification).
# ברירת-מחדל 300 שניות (5 דקות).
# DOMAIN_CACHE_TTL_SECONDS=300
